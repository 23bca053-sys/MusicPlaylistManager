<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.musicplaylistmanager">

    <application
        android:allowBackup="true"
        android:label="Music Playlist Manager"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MusicPlaylistManager">

        <activity
            android:name=".PlaylistDetailActivity"
            android:label="Playlist Details"
            android:exported="false" />
        <activity
            android:name=".CreatePlaylistActivity"
            android:label="Create New Playlist"
            android:exported="false" />

        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

    </application>

</manifest>